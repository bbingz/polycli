    "directory": "packages/polycli-utils"
  },
  "keywords": [
    "polycli",
    "cli",
    "utils",
    "ndjson",
    "atomic-save",
    "stream",
    "session-id"
  ],
  "type": "module",
  "files": [
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.js",
    "./args": "./src/args.js",
    "./process": "./src/process.js",
    "./stream": "./src/stream.js",
    "./atomic-save": "./src/atomic-save.js",
    "./ndjson": "./src/ndjson.js",
    "./session-id": "./src/session-id.js",
    "./parse-stream-json": "./src/parse-stream-json.js"
  }
}
